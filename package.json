{
  "name": "@botaoxyz/zhao",
  "version": "0.1.0",
  "description": "按域名、关键词和模块快速检索本地项目的 CLI",
  "bin": {
    "zhao": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.100tal.com/"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev": "bun src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --report-unused-disable-directives",
    "lint:fix": "oxlint . --fix --report-unused-disable-directives",
    "prepack": "pnpm build",
    "test": "vitest run --dir test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "citty": "^0.1.6",
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.9.0"
}
