{
  "name": "@botaoxyz/zhao",
  "version": "0.1.0",
  "description": "按域名、关键词和模块快速检索本地项目的 CLI",
  "type": "module",
  "bin": {
    "zhao": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun src/index.ts",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "https://npm.100tal.com/",
    "access": "restricted"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "citty": "^0.1.6",
    "fast-glob": "^3.3.3",
    "yaml": "^2.8.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.9.0"
}
