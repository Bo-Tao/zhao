{
  "name": "@botaoxyz/zhao",
  "version": "0.3.0",
  "description": "按域名、关键词和模块快速检索本地项目的 CLI",
  "author": "BoTao <botaoxyz@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bo-Tao/zhao.git"
  },
  "bin": {
    "zhao": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev": "bun src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --report-unused-disable-directives",
    "lint:fix": "oxlint . --fix --report-unused-disable-directives",
    "prepack": "pnpm build",
    "test": "vitest run --dir test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "citty": "^0.2.2",
    "fast-glob": "^3.3.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "tsdown": "^0.22.13",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.15.1"
}
